# =============================================================================
# ROSEN CUSW Team Flow — Variables de entorno para instalación local
# =============================================================================
# Copia este archivo a `.env` en la raíz del proyecto y sustituye los valores
# marcados como CAMBIAR. Genera aleatorios con:  openssl rand -hex 32
#
# Este `.env` cubre DOS escenarios:
#   A) Desarrollo local del SPA apuntando a un backend Supabase (Cloud o
#      self‑hosted). Sólo hacen falta las variables VITE_* de la sección 1.
#   B) Stack completo self‑hosted con `docker/docker-compose.yml`. En ese caso
#      copia también `docker/.env.example` a `docker/.env` y rellena las
#      variables de las secciones 2‑5 (las mismas viven allí para el compose).
#
# Ver guía completa: DEPLOYMENT.md (sección 11).
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Frontend (Vite) — leídas por src/integrations/supabase/client.ts
# -----------------------------------------------------------------------------
# URL pública del API gateway de Supabase (Kong en self‑hosted, o el dominio
# gestionado si usas Lovable Cloud).
VITE_SUPABASE_URL=http://localhost:8000

# Clave publishable/anon. Es pública por diseño (RLS protege los datos).
VITE_SUPABASE_PUBLISHABLE_KEY=CAMBIAR_anon_key_jwt

# Identificador del proyecto (cualquier slug para self‑hosted).
VITE_SUPABASE_PROJECT_ID=local


# -----------------------------------------------------------------------------
# 2. Postgres (self‑hosted)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=CAMBIAR_password_seguro


# -----------------------------------------------------------------------------
# 3. JWT compartido (GoTrue / PostgREST / Realtime)
# -----------------------------------------------------------------------------
# Mínimo 32 caracteres. Todos los servicios deben usar el mismo valor.
JWT_SECRET=CAMBIAR_jwt_secret_min_32_chars

# ANON_KEY y SERVICE_ROLE_KEY son JWT firmados con JWT_SECRET. Genera ambos
# siguiendo: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=CAMBIAR_jwt_anon
SERVICE_ROLE_KEY=CAMBIAR_jwt_service_role

# Base secreta de Realtime (64 chars).
REALTIME_SECRET_KEY_BASE=CAMBIAR_64_chars_aleatorio


# -----------------------------------------------------------------------------
# 4. URLs públicas
# -----------------------------------------------------------------------------
# URL desde donde el navegador accede a la SPA (para redirecciones de Auth).
SITE_URL=http://localhost:8080

# URL desde donde el navegador llama al API gateway.
PUBLIC_SUPABASE_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# 5. Edge Function `tfs-pat-vault`
# -----------------------------------------------------------------------------
# Clave AES‑256‑GCM (32 bytes en hex = 64 chars) para cifrar los PATs de
# Azure DevOps almacenados en la base de datos. Genera con:
#   openssl rand -hex 32
# Guárdala en un gestor de secretos y respáldala: si la pierdes, los PATs
# guardados quedan irrecuperables y hay que reintroducirlos.
ADO_PAT_ENC_KEY=CAMBIAR_64_hex_chars


# -----------------------------------------------------------------------------
# 6. Opcional — sólo si integras un TFS/Azure DevOps que necesite proxy
# -----------------------------------------------------------------------------
# Deja en blanco si el navegador puede llegar directamente al TFS (VPN activa).
# TFS_BASE_URL=https://tfs.tuempresa.local/tfs
