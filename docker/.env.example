# -----------------------------------------------------------------------------
# Copia este archivo a docker/.env y sustituye TODOS los valores marcados CAMBIAR.
# Genera los aleatorios con:  openssl rand -hex 32
# -----------------------------------------------------------------------------

# --- Postgres --------------------------------------------------------------
POSTGRES_PASSWORD=CAMBIAR_password_seguro

# --- JWT compartido por GoTrue / PostgREST / Realtime ---------------------
# Debe tener al menos 32 caracteres.
JWT_SECRET=CAMBIAR_jwt_secret_min_32_chars_aleatorio

# ANON_KEY y SERVICE_ROLE_KEY son JWT firmados con JWT_SECRET.
# Genéralos una sola vez con:
#   docker run --rm -e JWT_SECRET=$JWT_SECRET supabase/gotrue:v2.158.1 \
#     bash -c 'echo "role=anon"; ...'
# o usa https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=CAMBIAR_jwt_anon
SERVICE_ROLE_KEY=CAMBIAR_jwt_service_role

# --- Realtime --------------------------------------------------------------
REALTIME_SECRET_KEY_BASE=CAMBIAR_64_chars_aleatorio

# --- URLs públicas ---------------------------------------------------------
# URL desde donde el navegador accede a la SPA (para redirecciones de Auth).
SITE_URL=http://localhost:8080
# URL desde donde el navegador llama a la API Kong (misma máquina por defecto).
PUBLIC_SUPABASE_URL=http://localhost:8000

# --- Edge Function tfs-pat-vault ------------------------------------------
# Clave AES-256-GCM (32 bytes en hex = 64 chars) para cifrar los PATs de TFS.
ADO_PAT_ENC_KEY=CAMBIAR_64_hex_chars_openssl_rand_hex_32
